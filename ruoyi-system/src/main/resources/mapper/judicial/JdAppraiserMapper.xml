<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.JdAppraiserMapper">
    
    <resultMap type="JdAppraiser" id="JdAppraiserResult">
        <result property="id"    column="id"    />
        <result property="institutionId"    column="institution_id"    />
        <result property="name"    column="name"    />
        <result property="gender"    column="gender"    />
        <result property="idCard"    column="id_card"    />
        <result property="education"    column="education"    />
        <result property="professionalTitle"    column="professional_title"    />
        <result property="practiceCertNo"    column="practice_cert_no"    />
        <result property="practiceCategory"    column="practice_category"    />
        <result property="phone"    column="phone"    />
        <result property="certValidFrom"    column="cert_valid_from"    />
        <result property="certValidTo"    column="cert_valid_to"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectJdAppraiserVo">
        select id, institution_id, name, gender, id_card, education, professional_title, practice_cert_no, practice_category, phone, cert_valid_from, cert_valid_to, status, create_by, create_time, update_by, update_time, remark, del_flag from jd_appraiser
    </sql>

    <select id="selectJdAppraiserList" parameterType="JdAppraiser" resultMap="JdAppraiserResult">
        <include refid="selectJdAppraiserVo"/>
        <where>  
            <if test="institutionId != null "> and institution_id = #{institutionId}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="practiceCertNo != null  and practiceCertNo != ''"> and practice_cert_no = #{practiceCertNo}</if>
            <if test="practiceCategory != null  and practiceCategory != ''"> and practice_category = #{practiceCategory}</if>
            <if test="certValidTo != null "> and cert_valid_to = #{certValidTo}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectJdAppraiserById" parameterType="Long" resultMap="JdAppraiserResult">
        <include refid="selectJdAppraiserVo"/>
        where id = #{id}
    </select>

    <insert id="insertJdAppraiser" parameterType="JdAppraiser" useGeneratedKeys="true" keyProperty="id">
        insert into jd_appraiser
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="institutionId != null">institution_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="gender != null">gender,</if>
            <if test="idCard != null">id_card,</if>
            <if test="education != null">education,</if>
            <if test="professionalTitle != null">professional_title,</if>
            <if test="practiceCertNo != null and practiceCertNo != ''">practice_cert_no,</if>
            <if test="practiceCategory != null">practice_category,</if>
            <if test="phone != null">phone,</if>
            <if test="certValidFrom != null">cert_valid_from,</if>
            <if test="certValidTo != null">cert_valid_to,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="institutionId != null">#{institutionId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="gender != null">#{gender},</if>
            <if test="idCard != null">#{idCard},</if>
            <if test="education != null">#{education},</if>
            <if test="professionalTitle != null">#{professionalTitle},</if>
            <if test="practiceCertNo != null and practiceCertNo != ''">#{practiceCertNo},</if>
            <if test="practiceCategory != null">#{practiceCategory},</if>
            <if test="phone != null">#{phone},</if>
            <if test="certValidFrom != null">#{certValidFrom},</if>
            <if test="certValidTo != null">#{certValidTo},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateJdAppraiser" parameterType="JdAppraiser">
        update jd_appraiser
        <trim prefix="SET" suffixOverrides=",">
            <if test="institutionId != null">institution_id = #{institutionId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="education != null">education = #{education},</if>
            <if test="professionalTitle != null">professional_title = #{professionalTitle},</if>
            <if test="practiceCertNo != null and practiceCertNo != ''">practice_cert_no = #{practiceCertNo},</if>
            <if test="practiceCategory != null">practice_category = #{practiceCategory},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="certValidFrom != null">cert_valid_from = #{certValidFrom},</if>
            <if test="certValidTo != null">cert_valid_to = #{certValidTo},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteJdAppraiserById" parameterType="Long">
        delete from jd_appraiser where id = #{id}
    </delete>

    <delete id="deleteJdAppraiserByIds" parameterType="String">
        delete from jd_appraiser where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>